# Database
DATABASE_URL=sqlite:///./app.db

# JWT Settings
# IMPORTANT: Generate a secure SECRET_KEY using: openssl rand -hex 32
# The application will fail to start without a valid SECRET_KEY (min 32 characters)
SECRET_KEY=

ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=60

# App Settings
APP_TITLE=Sandbox Manager
DEBUG=False

# Host server IP for SSH jump host (used in SSH config generation)
HOST_SERVER_IP=10.10.1.1