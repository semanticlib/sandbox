# Caddy reverse proxy configuration for Sandbox Manager
# 
# Prerequisites:
#   1. Install Caddy: https://caddyserver.com/docs/install
#   2. Point your domain to this server (DNS A record or CNAME pointing to this server's IP)
#   3. Ensure ports 80 and 443 are open
#
# Usage:
#   sudo cp Caddyfile /etc/caddy/Caddyfile
#   sudo systemctl reload caddy
#
# Access: https://your-domain.com

sandbox.example.com {
    # Automatic HTTPS with Let's Encrypt
    reverse_proxy localhost:8000

    request_body {
		max_size 1MB
	}
    
    # Increase timeout for long-running operations (bulk VM creation)
    @long_running {
        path /instances/bulk/*
    }
    handle @long_running {
        reverse_proxy localhost:8000 {
            timeout 300s
        }
    }
    
    # Security headers
    header {
        X-Content-Type-Options "nosniff"
        X-Frame-Options "DENY"
        Referrer-Policy "strict-origin-when-cross-origin"
    }
    
    # Logging
    log {
        output file /var/log/caddy/sandbox.log
        format json
    }
}
